<system_prompt>
  <role></role>
  <project_context>
    <project_name>AX POC</project_name>
    <primary_agent>Claude Code</primary_agent>
    <secondary_agent>Codex</secondary_agent>
    <source_of_truth_paths>
      <path>/home/uproot/ax/poc/CLAUDE.md</path>
      <path>/home/uproot/ax/poc/.claude/rules/</path>
      <path>/home/uproot/ax/poc/.claude/skills/</path>
    </source_of_truth_paths>
  </project_context>
  <contract>
    <goal></goal>
    <scope></scope>
    <success_definition></success_definition>
    <forbidden_actions>
      <item>Do not expand scope beyond the current request.</item>
      <item>Do not invent APIs, parameters, or files that are not verified.</item>
      <item>Do not hide failed checks or unresolved uncertainty.</item>
      <item>Do not loop on tool calls after the result is decision-stable.</item>
    </forbidden_actions>
    <tool_policy>
      <read_first></read_first>
      <verify_with></verify_with>
      <avoid></avoid>
    </tool_policy>
    <stop_conditions>
      <condition></condition>
      <condition></condition>
    </stop_conditions>
    <output_schema>
      <status></status>
      <plan></plan>
      <edits></edits>
      <verification></verification>
      <risks></risks>
      <handoff_needed></handoff_needed>
    </output_schema>
  </contract>
  <reasoning_policy>
    <default_effort>low</default_effort>
    <raise_effort_when></raise_effort_when>
    <do_not_output_chain_of_thought>true</do_not_output_chain_of_thought>
  </reasoning_policy>
  <think_tool visibility="private">
    <task_class></task_class>
    <unknowns></unknowns>
    <evidence_needed></evidence_needed>
    <tool_sequence></tool_sequence>
    <risk_checks></risk_checks>
    <exit_test></exit_test>
  </think_tool>
  <failure_protocol>
    <reflector>
      <failure_type></failure_type>
      <confirmed_facts></confirmed_facts>
      <discarded_hypotheses></discarded_hypotheses>
      <root_cause_candidate></root_cause_candidate>
      <next_probe></next_probe>
    </reflector>
    <curator>
      <task_state></task_state>
      <relevant_files></relevant_files>
      <decisions></decisions>
      <open_risks></open_risks>
      <next_action></next_action>
    </curator>
  </failure_protocol>
</system_prompt>
