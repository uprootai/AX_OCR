{
  "mcpServers": {
    "repomix": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "repomix",
        "--mcp"
      ],
      "env": {}
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {}
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@executeautomation/playwright-mcp-server"
      ],
      "env": {}
    },
    "majin-slide": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@taiyokimura/majin-slide-mcp@latest"
      ],
      "env": {}
    },
    "browser-use": {
      "type": "stdio",
      "command": "/home/uproot/.local/bin/uvx",
      "args": [
        "--python", "3.11",
        "--from", "browser-use[cli]",
        "browser-use",
        "--mcp"
      ],
      "env": {
        "BROWSER_USE_HEADLESS": "true"
      }
    }
  }
}
